# services/catalog — data catalog + data API configuration.
#
# Copy to .env for local development. Everything is optional: the defaults are
# local-first (SQLite + a local blob directory, no external services).
#
# NOTE: the VERITY_CATALOG_* settings below are read through pydantic-settings
# (verity_catalog/config.py), which loads this .env file automatically. The
# variables in the "API runtime" and "Benchmark" sections are read straight
# from the process environment (os.environ) at import/request time, so for
# local runs export them in your shell (or use `uv run --env-file .env ...`);
# in deployment they are plain service env vars either way.

# ------------------------------------------------------------------ database
# SQLAlchemy database URL. Default: sqlite:///verity_catalog.db
# Deploy target is Postgres via psycopg3, e.g.
#   postgresql+psycopg://user:password@host:5432/postgres?sslmode=require
VERITY_CATALOG_DATABASE_URL=sqlite:///verity_catalog.db

# ---------------------------------------------------------------- blob store
# Content-addressed store backend: "local" (default) or "s3".
VERITY_CATALOG_BLOB_STORE_BACKEND=local

# Local-backend paths for raw scans and derived artifacts.
# Defaults: .verity/blobs and .verity/artifacts
VERITY_CATALOG_BLOB_STORE_PATH=.verity/blobs
VERITY_CATALOG_ARTIFACT_STORE_PATH=.verity/artifacts

# --------------------------------------------- s3 backend (R2 / S3 / MinIO)
# Only used when VERITY_CATALOG_BLOB_STORE_BACKEND=s3.
# Endpoint: leave unset for AWS; for Cloudflare R2 use
#   https://<account-id>.r2.cloudflarestorage.com
VERITY_CATALOG_BLOB_STORE_ENDPOINT_URL=

# Bucket for raw scans (required for the s3 backend).
VERITY_CATALOG_BLOB_STORE_BUCKET=

# Bucket for derived artifacts; falls back to the scans bucket when unset.
VERITY_CATALOG_ARTIFACT_STORE_BUCKET=

# Region: "auto" for R2 (default); e.g. "us-east-1" for AWS.
VERITY_CATALOG_S3_REGION=auto

# Credentials; when unset, the standard boto3/AWS credential chain is used.
# Never commit real values.
VERITY_CATALOG_S3_ACCESS_KEY_ID=
VERITY_CATALOG_S3_SECRET_ACCESS_KEY=

# Optional public base URL for objects (e.g. an R2 custom domain). When set,
# /scans/{id}/x3p 302-redirects to "{base}/<sharded-key>" instead of streaming.
VERITY_CATALOG_BLOB_STORE_PUBLIC_BASE_URL=

# -------------------------------------------------------------- API runtime
# (read from os.environ, not the pydantic Settings — see NOTE above)

# Port the `verity-catalog-api` server binds (Railway injects this). Default: 8001
PORT=8001

# Comma-separated CORS allowlist for the data API.
# Default: https://verity.codes
VERITY_CATALOG_CORS_ORIGINS=https://verity.codes

# Request-body cap in bytes; oversized requests are rejected early.
# Default when unset: 64 MiB.
VERITY_CATALOG_MAX_BODY_BYTES=

# Public base URL baked into replication-kit manifests (benchmark/kit.py),
# e.g. https://data.verity.codes. Unset => derived from the request.
VERITY_CATALOG_PUBLIC_URL=

# ---------------------------------------------------------------- benchmark
# Shared token benchmark submissions must present; unset => open submissions.
# Use a long random string in production; never commit a real one.
VERITY_BENCHMARK_SUBMIT_TOKEN=

# Submission rate limit: max submissions per client IP per window.
# Defaults: 5 per 3600 seconds.
VERITY_BENCHMARK_RATE_LIMIT=5
VERITY_BENCHMARK_RATE_WINDOW_S=3600

# Set to 1 ONLY behind a trusted proxy/edge (e.g. Railway) so rate limiting
# keys on the client IP the edge appends to X-Forwarded-For. Default: off.
VERITY_TRUST_PROXY_HEADERS=

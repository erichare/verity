# services/web — Next.js client configuration.
#
# Copy to .env.local for local development. Every variable here is NEXT_PUBLIC_*
# (inlined into the client bundle at BUILD time — a change requires a rebuild),
# so nothing in this file is a secret. All variables are optional; the defaults
# shown in the comments are what the code falls back to.

# Base URL of the comparison API (lib/api.ts, lib/stepApi.ts).
# Default: http://127.0.0.1:8000 — production uses https://api.verity.codes
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000

# Client-side timeout for long comparison calls, in milliseconds (lib/http.ts).
# Default: 600000 (10 min). Set 0 to disable the client timeout entirely.
NEXT_PUBLIC_API_TIMEOUT_MS=600000

# Base URL of the catalog/benchmark data API — kit downloads + scored
# submissions (lib/benchmark.ts). Default: https://data.verity.codes
NEXT_PUBLIC_DATA_API_URL=https://data.verity.codes

# Supabase project URL for the read-only hosted catalog + benchmark leaderboard
# (lib/catalog.ts, lib/benchmark.ts). Unset => those UI sections show as
# "not configured" instead of erroring.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anon (publishable) key. This key is public by design; the tables it
# can reach are SELECT-only under row-level security. NOT the service-role key.
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
